<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="24dp">

    <EditText android:id="@+id/loginUser" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Username" />

    <EditText android:id="@+id/loginPass" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="Password" android:inputType="textPassword"
        android:layout_marginTop="16dp"/>

    <Button android:id="@+id/btnLogin" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Login" android:layout_marginTop="24dp"/>

    <Button android:id="@+id/btnBiometric"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Sign in with Fingerprint"
        android:layout_marginTop="12dp"
        android:visibility="gone"/>

    <Button android:id="@+id/btnGoToSignup"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Sign Up" android:layout_marginTop="16dp"/>

    <Button android:id="@+id/btnHomeFromLogin"
        style="?android:attr/borderlessButtonStyle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Heim / Loka" android:layout_marginTop="8dp"/>
</LinearLayout>